# Copy to .env at workspace root and fill in.

# --- Ports ---
# api on 8080, web on 3000 in dev.
PORT=3000
API_PORT=8080
WEB_ORIGIN=http://localhost:3000

# Used by the Next.js frontend at build/runtime to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# --- Mongo ---
MONGO_URI=mongodb://localhost:27017/cityfix

# --- JWT ---
# Generate a 32+ char random string. Anything in dev, never reuse in prod.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Google OAuth (optional in dev) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# --- File storage ---
# Driver: local (default). Future: s3, cloudinary.
STORAGE_DRIVER=local
LOCAL_UPLOADS_DIR=./uploads
MAX_UPLOAD_BYTES=10485760
